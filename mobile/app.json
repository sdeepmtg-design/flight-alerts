{
  "expo": {
    "name": "Flight Alerts",
    "slug": "flight-alerts",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "flightalerts",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.you.flightalerts"
    },
    "android": {
      "package": "com.you.flightalerts",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      }
    },
    "plugins": [
      "expo-notifications",
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "apiUrl": "https://flight-alerts-api.onrender.com",
      "eas": {
        "projectId": "ba4d0f62-f9f3-4725-a3ac-a851dd3f92b1"
      }
    },
    "owner": "sdeepmtg"
  }
}
